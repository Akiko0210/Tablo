# --- Required ---------------------------------------------------------------

# Postgres connection string (local Docker in dev, pooled Neon URL in prod).
DATABASE_URL="postgresql://tablo:tablo@localhost:5432/tablo"

# Secret for signing kitchen-device JWTs and session infrastructure.
# REQUIRED in production — the server refuses to boot without it.
# Generate one: openssl rand -base64 32
AUTH_SECRET=""

# --- Optional (features degrade gracefully without them) ---------------------

# Claude API key for photo → menu extraction. Without it, AI generation fails
# with a friendly hint and items can be added by hand.
ANTHROPIC_API_KEY=""

# Resend for verification / password-reset emails. Without it, emails are
# logged to the server console (fine for dev).
RESEND_API_KEY=""
EMAIL_FROM="Tablo <no-reply@example.com>"

# Absolute origin used in emailed links, e.g. https://tablo.example.com
APP_URL="http://localhost:3000"

# Cloudflare R2 (S3-compatible) for upload bytes. Without these, bytes are
# stored in Postgres (dev fallback).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Public base URL of the bucket (custom domain or r2.dev), no trailing slash.
R2_PUBLIC_URL=""
